rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: lê a permissão do usuário logado
    function userPerm() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data.perm;
    }

    // MEMBROS — leitura para logados, escrita só para admin
    match /members/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userPerm() == 'admin';
    }

    // EVENTOS — leitura pública, escrita para admin/secretário
    match /events/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'secretario'];
    }

    // INSCRIÇÕES — qualquer um pode criar, logados podem ler
    match /inscricoes/{doc} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null &&
        userPerm() in ['admin', 'secretario'];
    }

    // FINANÇAS — leitura para logados, escrita para admin/tesoureiro
    match /finance/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'tesoureiro'];
    }

    // BALANCETES — leitura para logados, escrita para admin/tesoureiro
    match /balancetes/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'tesoureiro'];
    }

    // ATAS — leitura para logados, escrita para admin/secretário
    match /atas/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'secretario'];
    }

    // TURMAS DE EDUCAÇÃO — leitura pública, escrita para professor/admin
    match /turmas/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'professor'];
    }

    // MATERIAIS DE EDUCAÇÃO — leitura pública, escrita para professor/admin
    match /materiais/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
        userPerm() in ['admin', 'professor'];
    }

    // PREGAÇÕES — leitura pública, escrita só para admin
    match /pregacoes/{doc} {
      allow read: if true;
      allow write: if request.auth != null && userPerm() == 'admin';
    }
  }
}
